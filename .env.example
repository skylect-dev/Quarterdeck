HOST=127.0.0.1
PORT=3099
# Optional. Set a password to enable the built-in login screen.
APP_PASSWORD=
# Recommended when APP_PASSWORD is enabled. If omitted, APP_PASSWORD is used as the signing secret.
SESSION_SECRET=
# Session login duration in hours when "Remember this browser" is not checked.
SESSION_TTL_HOURS=12
# Persistent login duration in days when "Remember this browser" is checked.
REMEMBER_LOGIN_DAYS=30
# Set to true only when the browser reaches the app over HTTPS, such as Cloudflare Tunnel.
COOKIE_SECURE=false
# Login rate-limit window in milliseconds.
LOGIN_WINDOW_MS=600000
# Max failed login attempts allowed within LOGIN_WINDOW_MS before lockout.
LOGIN_MAX_ATTEMPTS=8
# Lockout duration in milliseconds after too many failed attempts.
LOGIN_LOCKOUT_MS=900000
# Set to false to hide the Systemd tab and disable systemd control endpoints.
ENABLE_SYSTEMD=true
